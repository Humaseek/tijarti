{
  "name": "tijarti",
  "version": "0.1.0",
  "private": true,
  "description": "Tijarti — financial management for Arab-Israeli SMBs. Monorepo: web (Next.js), mobile (Expo, soon), shared types + business logic.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@tijarti/web",
    "dev:web": "npm run dev --workspace=@tijarti/web",
    "build": "npm run build --workspace=@tijarti/web",
    "build:web": "npm run build --workspace=@tijarti/web",
    "lint": "npm run lint --workspace=@tijarti/web",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "engines": {
    "node": ">=18.17.0",
    "npm": ">=9.0.0"
  }
}
